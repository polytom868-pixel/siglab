# SigLab core-code .gitignore
# Tracks: siglab/ + docs/ + .agents/ + scripts/ + config files
# Ignores: tests/ (junk), agent_workspace/ (junk), temp, one-off, logs

# ----- Python -----
__pycache__/
*.py[cod]
*.pyo
*.pyd
*$py.class
*.so
*.egg-info/
*.egg

# ----- Virtual envs -----
.venv/
venv/
env/

# ----- Test/cache/runtime junk -----
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.prof
*.lprof
*.npy

# ----- OS -----
.DS_Store
Thumbs.db

# ----- Tooling -----
.omc/
.claude/
.wayfinder/
.cursor/
.idea/
.vscode/

# ----- Logs -----
*.log
dashboard_*.log

# ----- Local env / secrets -----
.env
.env.*
.siglab-provider.env
config.json
config.local.json
*.db
*.db.*
lineage.db
new_empty_check.db

# ----- SigLab runtime artefacts (state, snapshots, etc.) -----
runs/
backups/

# ----- ALL TESTS, scratch notes, agent work — keep repo CORE only -----
tests/
agent_workspace/
tmp/
scratch/
oneoff/
one_offs/
junk/
logs/
benchmarks/
scripts/
.agents/
.claude/
.cursor/
.idea/
.vscode/
.mcp.json
.env
.env.*

# ----- Reports, audits, plans, scratch work -----
reports/

# ----- Deployed agent credentials / private config (keep __init__) -----
siglab/live/deployed_agents/*
!siglab/live/deployed_agents/__init__.py

# ----- ALL TESTS, scratch notes, agent work — keep repo CORE only -----
tests/
agent_workspace/
tmp/
scratch/
oneoff/
one_offs/
junk/
logs/

# ----- Auto-generated noise inside docs (overridden by per-file allow) -----
docs/*gap*
docs/*audit*.md
docs/*validation*.md
docs/refactor-correction-report.md
docs/*surface*.yaml

# ----- Misc auto-generated -----
.idea/
*.swp
*.bak
*.tmp
