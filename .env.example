SIGLAB_POPULATION_SIZE=4
SIGLAB_OPTUNA_TRIALS=20
SIGLAB_MEMORY_SCOPE=session_local
SIGLAB_USE_HISTORICAL_SEEDS=false
SIGLAB_AGENT_DEPLOY_DIR=siglab/live/deployed_agents

TAVILY_API_KEY=
TAVILY_MAX_RESULTS=5
WEB_EXPLORE_RESULTS_PER_QUERY=2
