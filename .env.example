SOSOVALUE_CONFIG_PATH=./config.json
SOSOVALUE_API_KEY=

LLM_PROVIDER=claude

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_THINKING=enabled
CLAUDE_MAX_TOOL_ROUNDS=6
CLAUDE_MAX_TOKENS=
