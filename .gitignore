# SigLab core-code .gitignore
# Tracks: siglab/ + docs/ + .agents/ + scripts/ + config files
# Ignores: tests/ (junk), agent_workspace/ (junk), temp, one-off, logs

# ----- Python -----
__pycache__/
*.py[cod]
*.pyo
*.pyd
*$py*.class
*.so
*.egg-info/
*.egg

# ----- Virtual envs -----
.venv/
venv/
env/

# ----- Test/cache/runtime junk -----
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.prof
*.lprof
*.npy
*.parquet

# ----- OS -----
.DS_Store
Thumbs.db

# ----- Tooling -----
.omc/
.claude/
.wayfinder/
.cursor/
.idea/
.vscode/

# ----- Logs -----
*.log
dashboard_*.log

# ----- Local env / secrets -----
.env
.env.*
.siglab-provider.env
config.json
config.local.json
*.db
*.db.*
lineage.db
new_empty_check.db

# ----- SigLab runtime artefacts (state, snapshots, etc.) -----
runs/
backups/

# ----- ALL TESTS, scratch notes, agent work — keep repo CORE only -----
tests/
agent_workspace/
tmp/
scratch/
oneoff/
one_offs/
junk/
logs/
benchmarks/
scripts/
.agents/
.mcp.json
reports/

# ----- Cache / runtime artifacts -----
data/cache/
sessions/

# ----- Local experiment config -----
mutable/
challenges/
tracks/

# ----- Wallet / key material -----
*.key
*_key*
wallet*

# ----- Deployed agent credentials / private config (keep __init__) -----
siglab/live/deployed_agents/*
!siglab/live/deployed_agents/__init__.py

# ----- Auto-generated noise inside docs -----
docs/*gap*
docs/*audit*.md
docs/*validation*.md
docs/refactor-correction-report.md
docs/*surface*.yaml
docs/screenshots/

# ----- Root-level generated artifacts -----
tmp_git_cmd.sh
git-ls-files-output.txt

# ----- Misc auto-generated -----
*.swp
*.bak
*.tmp

# Non-essential generated/report files
AUDIT.md
CRITICAL_AUDIT.md
DEEP_AUDIT.md
DEEP_OPTIMIZATION_AUDIT.md
E6_REPORT.md
EVALUATION_REPORT.md
FINAL_BENCHMARK.md
LIVE_SYSTEM_REPORT.md
OPTIMIZATION_BLUEPRINT.md
PATH_TO_10K.md
ULTIMATE_AUDIT.md
ULTRA_AUDIT.md
VERIFIED_PLAN.md
_sosovalue_decision_report.md
coverage.json
coverage_full.json
coverage_full2.json
coverage_run.json
coverage_unit.json
DESIGN.md
PRODUCT.md
config.example.json
sosovalue_api_schema.json
demo_steps.yaml

# Orphan docs
docs/access-and-testnet-plan.md
docs/demo-script.md
docs/iter*.md
docs/loop-supervision.md
docs/module-*.md
docs/production-hardening.md
docs/provider-routing.md
docs/rich-formatting-strategy.md
docs/screenshots/
docs/skills-activation.md
docs/tuning-guide.md
.coveragerc

# Non-critical (untracked)
.github/
AGENTS.md
CONTRIBUTING.md
Dockerfile
mypy.ini
poetry.lock
pytest.ini
siglab/demo_steps.yaml
siglab/assets/demo_manifest.html
siglab/assets/demo_report.html
siglab/dashboard/templates/macros.html
siglab/dashboard/templates/partials/ops/_macros.html
local:/

local:/
siglab/data/sosovalue_capabilities.yaml
siglab/dashboard/static/app.js
siglab/evaluation/__init__.py
siglab/live/__init__.py
siglab/operator/__init__.py
